2026-01-23 14:26:49,359 DEBUG openai._base_client: HTTP Response: POST https://api.openai.com/v1/responses "200 OK" Headers({'date': 'Fri, 23 Jan 2026 10:26:49 GMT', 'content-type': 'application/json', 'transfer-encoding': 'chunked', 'connection': 'keep-alive', 'x-ratelimit-limit-requests': '10000', 'x-ratelimit-limit-tokens': '4000000', 'x-ratelimit-remaining-requests': '9999', 'x-ratelimit-remaining-tokens': '3996482', 'x-ratelimit-reset-requests': '6ms', 'x-ratelimit-reset-tokens': '52ms', 'openai-version': '2020-10-01', 'openai-organization': 'divento', 'openai-project': 'proj_lgr47s5G9zYA1BjFZQpHGMQB', 'x-request-id': 'req_a27f2babfb074699a1d26fc889f3a4f6', 'openai-processing-ms': '26502', 'x-envoy-upstream-service-time': '26506', 'cf-cache-status': 'DYNAMIC', 'strict-transport-security': 'max-age=31536000; includeSubDomains; preload', 'x-content-type-options': 'nosniff', 'server': 'cloudflare', 'cf-ray': '9c2697ab6c2e90e3-TBS', 'content-encoding': 'gzip', 'alt-svc': 'h3=":443"; ma=86400'})
