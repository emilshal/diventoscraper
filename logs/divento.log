2026-01-23 14:33:53,497 DEBUG openai._base_client: HTTP Response: POST https://api.openai.com/v1/responses "200 OK" Headers({'date': 'Fri, 23 Jan 2026 10:33:53 GMT', 'content-type': 'application/json', 'transfer-encoding': 'chunked', 'connection': 'keep-alive', 'x-ratelimit-limit-requests': '10000', 'x-ratelimit-limit-tokens': '4000000', 'x-ratelimit-remaining-requests': '9999', 'x-ratelimit-remaining-tokens': '3996535', 'x-ratelimit-reset-requests': '6ms', 'x-ratelimit-reset-tokens': '51ms', 'openai-version': '2020-10-01', 'openai-organization': 'divento', 'openai-project': 'proj_lgr47s5G9zYA1BjFZQpHGMQB', 'x-request-id': 'req_a66b69de2cc6405a9d9ef3b570473baf', 'openai-processing-ms': '29432', 'x-envoy-upstream-service-time': '29430', 'cf-cache-status': 'DYNAMIC', 'strict-transport-security': 'max-age=31536000; includeSubDomains; preload', 'x-content-type-options': 'nosniff', 'server': 'cloudflare', 'cf-ray': '9c26a1f41e1395a0-TBS', 'content-encoding': 'gzip', 'alt-svc': 'h3=":443"; ma=86400'})
