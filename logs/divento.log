2026-01-23 14:27:59,682 DEBUG openai._base_client: HTTP Response: POST https://api.openai.com/v1/responses "200 OK" Headers({'date': 'Fri, 23 Jan 2026 10:27:59 GMT', 'content-type': 'application/json', 'transfer-encoding': 'chunked', 'connection': 'keep-alive', 'x-ratelimit-limit-requests': '10000', 'x-ratelimit-limit-tokens': '4000000', 'x-ratelimit-remaining-requests': '9999', 'x-ratelimit-remaining-tokens': '3996399', 'x-ratelimit-reset-requests': '6ms', 'x-ratelimit-reset-tokens': '54ms', 'openai-version': '2020-10-01', 'openai-organization': 'divento', 'openai-project': 'proj_lgr47s5G9zYA1BjFZQpHGMQB', 'x-request-id': 'req_64db4f6f3b774ff9b41a9cae68f85e66', 'openai-processing-ms': '55571', 'x-envoy-upstream-service-time': '55573', 'cf-cache-status': 'DYNAMIC', 'strict-transport-security': 'max-age=31536000; includeSubDomains; preload', 'x-content-type-options': 'nosniff', 'server': 'cloudflare', 'cf-ray': '9c2698ad6a594e68-TBS', 'content-encoding': 'gzip', 'alt-svc': 'h3=":443"; ma=86400'})
